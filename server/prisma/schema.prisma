generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum PriceLevel {
  CHEAP
  MODERATE
  EXPENSIVE
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      UserRole   @default(USER)
  reviews   Review[]
  favorites Favorite[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Restaurant {
  id             String      @id @default(uuid())
  name           String
  description    String
  category       String
  address        String
  latitude       Float
  longitude      Float
  priceLevel     PriceLevel
  imageUrl       String?
  openingHours   String?
  phone          String?
  website        String?
  externalSource String?
  externalId     String?
  isTrending     Boolean     @default(false)
  isHiddenGem    Boolean     @default(false)
  isAffordable   Boolean     @default(false)
  isVerified     Boolean     @default(false)
  reviews        Review[]
  favorites      Favorite[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([externalSource, externalId])
}

model Review {
  id           String     @id @default(uuid())
  rating       Int
  comment      String
  userId       String
  restaurantId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, restaurantId])
}

model Favorite {
  id           String     @id @default(uuid())
  userId       String
  restaurantId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, restaurantId])
}
